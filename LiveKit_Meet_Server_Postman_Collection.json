							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"event\": \"room_started\",\n  \"room\": {\n    \"name\": \"test-room\",\n    \"sid\": \"RM_test123\"\n  },\n  \"participant\": {\n    \"identity\": \"test-user\",\n    \"sid\": \"PA_test456\"\n  },\n  \"createdAt\": {{$timestamp}}\n}"
						},
