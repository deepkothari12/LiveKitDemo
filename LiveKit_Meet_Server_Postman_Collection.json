{
	"info": {
		"_postman_id": "livekit-meet-server-api",
		"name": "LiveKit Meet Server API",
		"description": "Complete API collection for LiveKit Meet Server with automatic recording and transcription",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "testRoomName",
			"value": "test-room-{{$randomInt}}",
			"type": "string"
		},
		{
			"key": "testParticipant",
			"value": "test-user-{{$randomFirstName}}",
			"type": "string"
		},
		{
			"key": "existingRoom",
			"value": "aurora-1737",
			"type": "string"
		},
		{
			"key": "egressId",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "🔐 Authentication & Token Management",
			"item": [
				{
					"name": "Generate Access Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has token\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('token');",
									"    pm.expect(jsonData).to.have.property('url');",
									"    pm.expect(jsonData).to.have.property('isCreator');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"roomName\": \"{{testRoomName}}\",\n  \"participantName\": \"{{testParticipant}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/token",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"token"
							]
						},
						"description": "Generate JWT access token for LiveKit room. Creates room creator if first participant."
					}
				}
			]
		},
		{
			"name": "⚙️ Server Configuration",
			"item": [
				{
					"name": "Get Server Config",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has livekitUrl\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('livekitUrl');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/config",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"config"
							]
						},
						"description": "Get basic server configuration including LiveKit URL."
					}
				}
			]
		},
		{
			"name": "🎬 Recording Management",
			"item": [
				{
					"name": "Get Recording Room State",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has recording state\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('active');",
									"    pm.expect(jsonData).to.have.property('creator');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/recording/room/{{existingRoom}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recording",
								"room",
								"{{existingRoom}}"
							]
						},
						"description": "Check if a room is currently being recorded and get recording details."
					}
				},
				{
					"name": "Start Recording",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 409\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 409, 400]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Recording started successfully\", function () {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('message');",
									"        pm.expect(jsonData).to.have.property('started');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"roomName\": \"{{testRoomName}}\",\n  \"startedBy\": \"{{testParticipant}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/recording/start",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recording",
								"start"
							]
						},
						"description": "Start recording for a room. Only room creator can start recording."
					}
				},
				{
					"name": "Stop Recording",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 404\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404, 403]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Recording stopped successfully\", function () {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('message');",
									"        pm.expect(jsonData).to.have.property('stopped');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"roomName\": \"{{testRoomName}}\",\n  \"requestedBy\": \"{{testParticipant}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/recording/stop",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recording",
								"stop"
							]
						},
						"description": "Stop recording for a room. Only the person who started recording can stop it."
					}
				},
				{
					"name": "Get Egress Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 404\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Egress status returned\", function () {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('egressId');",
									"        pm.expect(jsonData).to.have.property('status');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/recording/status/EG_example123",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recording",
								"status",
								"EG_example123"
							]
						},
						"description": "Get status of a specific recording egress by ID."
					}
				},
				{
					"name": "List Room Egresses",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has egresses list\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('roomName');",
									"    pm.expect(jsonData).to.have.property('egresses');",
									"    pm.expect(jsonData).to.have.property('count');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/recording/list/{{existingRoom}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recording",
								"list",
								"{{existingRoom}}"
							]
						},
						"description": "List all recording egresses for a specific room."
					}
				}
			]
		},
		{
			"name": "📝 Transcription Management",
			"item": [
				{
					"name": "Get Transcript",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 404\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Transcript data returned\", function () {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('roomName');",
									"        pm.expect(jsonData).to.have.property('participants');",
									"        pm.expect(jsonData).to.have.property('segments');",
									"        pm.expect(jsonData).to.have.property('fullText');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/transcript/{{existingRoom}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"transcript",
								"{{existingRoom}}"
							]
						},
						"description": "Get the transcript for a completed meeting room."
					}
				},
				{
					"name": "Manual Transcribe",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 500\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 500]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Transcription started\", function () {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('message');",
									"        pm.expect(jsonData).to.have.property('roomName');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/transcribe/{{existingRoom}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"transcribe",
								"{{existingRoom}}"
							]
						},
						"description": "Manually trigger transcription for a room with recordings."
					}
				}
			]
		},
		{
			"name": "🔍 Monitoring & Status",
			"item": [
				{
					"name": "Webhook Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Status data returned\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('webhook_url');",
									"    pm.expect(jsonData).to.have.property('livekit_url');",
									"    pm.expect(jsonData).to.have.property('auto_recording_enabled');",
									"    pm.expect(jsonData).to.have.property('transcription_monitor_running');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/webhook-status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"webhook-status"
							]
						},
						"description": "Get comprehensive server status including webhook configuration, active rooms, and transcription monitor status."
					}
				},
				{
					"name": "Rooms Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Rooms data returned\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('rooms');",
									"    pm.expect(jsonData).to.have.property('total_rooms');",
									"    pm.expect(jsonData).to.have.property('rooms_with_transcripts');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/rooms-status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"rooms-status"
							]
						},
						"description": "Get status of all rooms in S3 including file counts and transcription status."
					}
				},
				{
					"name": "Check Transcriptions",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 503\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 503]);",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    pm.test(\"Transcription check completed\", function () {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('message');",
									"        pm.expect(jsonData).to.have.property('processed_rooms');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/check-transcriptions",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"check-transcriptions"
							]
						},
						"description": "Manually trigger the automatic transcription monitor to check all rooms."
					}
				}
			]
		},
