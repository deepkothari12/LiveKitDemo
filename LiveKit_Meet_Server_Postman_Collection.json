	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Set dynamic variables for each request",
					"if (!pm.collectionVariables.get('testRoomName')) {",
					"    pm.collectionVariables.set('testRoomName', 'test-room-' + Math.floor(Math.random() * 1000));",
					"}",
					"if (!pm.collectionVariables.get('testParticipant')) {",
					"    pm.collectionVariables.set('testParticipant', 'test-user-' + Math.floor(Math.random() * 100));",
					"}"
				]
			}
		}
	]
}